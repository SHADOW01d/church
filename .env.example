# Copy to .env and fill in. NEVER commit the real .env file.

# Which settings module to load (config.settings.dev | config.settings.prod)
DJANGO_SETTINGS_MODULE=config.settings.dev

# Toggle debug. Always False in production.
DEBUG=True

# REQUIRED in production. Generate one with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=change-me

# Comma-separated hostnames the site is served from (no scheme).
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated origins (WITH scheme) trusted for CSRF, e.g. https://example.org
DJANGO_CSRF_TRUSTED_ORIGINS=

# Database. Defaults to local SQLite if unset. Example for Postgres:
#   DATABASE_URL=postgres://user:password@localhost:5432/church
# DATABASE_URL=

# ── Production-only ─────────────────────────────────────────────
# DJANGO_SECURE_SSL_REDIRECT=True
# DJANGO_SECURE_HSTS_SECONDS=31536000
# DJANGO_LOG_LEVEL=INFO

# Email (used by config.settings.prod)
# EMAIL_HOST=
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=Gilgal Dominion Center <noreply@example.com>
